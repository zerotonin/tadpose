{
  "active_profile": "local",
  "profiles": {
    "local": {
      "data_root": "/path/to/your/tadpole_project",
      "code_root": "/path/to/your/checkout/tadpose",
      "python_interpreter": "python",
      "dlc_config_path": "/path/to/deeplabcut_models/single_tadpole/config.yaml"
    },
    "hpc": {
      "data_root": "/path/to/cluster/tadpole_project",
      "code_root": "/path/to/your/cluster/checkout/tadpose",
      "python_interpreter": "/path/to/conda/envs/deeplabcut/bin/python",
      "dlc_config_path": "/path/to/cluster/tadpole_project/models/dlc_single_tadpole/config.yaml",
      "db_path": "/path/to/cluster/tadpole_project/databases/your_db.sqlite3",
      "output_root": "/path/to/cluster/tadpole_project/results/pipeline/<batch>",
      "videos_root": "/path/to/cluster/tadpole_project/videos/raw/<batch>",
      "conda_env": "deeplabcut",
      "partition": "<your-slurm-partition>",
      "account": "<your-slurm-account>"
    }
  }
}
